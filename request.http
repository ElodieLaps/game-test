### add character equipments
PUT http://localhost:3000/character/f3d7591d-59b0-48a8-aed1-bd73a99cf47d/equipments/add
Content-Type: application/json

[
    {
        "slot": "WEAPON",
        "weaponTypeName": "STAFF",
        "name": "Wooden Staff",
        "statistics": [
            { "name": "POWER", "value": 3 }
        ]
    },
    {
        "slot": "SHIELD",
        "weaponTypeName": "SWORD",
        "name": "Wooden Shield",
        "statistics": [
            { "name": "STRENGTH", "value": 3 }
        ]
    }
]

### remove character equipments
PUT http://localhost:3000/character/f3d7591d-59b0-48a8-aed1-bd73a99cf47d/equipments/remove
Content-Type: application/json

[
    "HEAD",
    "SHIELD"
]

### remove all character equipments
PUT http://localhost:3000/character/f3d7591d-59b0-48a8-aed1-bd73a99cf47d/equipments/removeAll 

